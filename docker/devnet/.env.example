# ---------------------------------------------------------------------------
# StellarLend Devnet -- Environment Variables
# Copy to .env and adjust as needed:  cp .env.example .env
# ---------------------------------------------------------------------------

# -- Ports (host-side) -----------------------------------------------------
SOROBAN_RPC_PORT=8000
FRIENDBOT_PORT=8001
API_PORT=3000
ORACLE_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379

# -- API configuration -----------------------------------------------------
JWT_SECRET=devnet-jwt-secret-do-not-use-in-prod
CONTRACT_ID=PLACEHOLDER_CONTRACT_ID

# -- Soroban / Stellar network ---------------------------------------------
NETWORK_PASSPHRASE="Standalone Network ; February 2017"
SOROBAN_RPC_URL=http://localhost:8000/soroban/rpc
HORIZON_URL=http://localhost:8000
FRIENDBOT_URL=http://localhost:8000/friendbot

# -- Init script tuning ----------------------------------------------------
# Maximum seconds to wait for the devnet node to become healthy
HEALTH_TIMEOUT=120
# Number of test user accounts to create (user1 .. userN)
NUM_TEST_USERS=5
# Initial XLM funding per test account (via friendbot)
INITIAL_XLM=10000
